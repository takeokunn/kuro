//! POSIX PTY implementation using libc for PTY operations

use crate::{error::KuroError, pty::reader::PtyReader, Result};
use std::os::unix::io::{AsRawFd, FromRawFd, RawFd};
use std::process::Command;
use std::sync::atomic::{AtomicBool, Ordering};
use std::sync::Arc;
use std::thread;

/// Channel capacity for PTY data - prevents unbounded memory growth
const CHANNEL_CAPACITY: usize = 100;

/// PTY master handle
pub struct Pty {
    /// Master file descriptor
    master: std::fs::File,
    /// Child process ID
    child_pid: libc::pid_t,
    /// Channel for receiving PTY output (bounded for backpressure)
    receiver: crossbeam_channel::Receiver<Vec<u8>>,
    /// Shutdown signal for reader thread
    shutdown: Arc<AtomicBool>,
    /// Thread handle for PTY reader
    _reader_thread: thread::JoinHandle<()>,
}

impl Pty {
    /// Spawn a new PTY with the given command
    pub fn spawn(command: &str) -> Result<Self> {
        // Open PTY master
        let master_fd = unsafe {
            // Use posix_openpt on Linux/macOS
            let fd = libc::posix_openpt(libc::O_RDWR);

            if fd == -1 {
                return Err(KuroError::Pty("Failed to open PTY".to_string()));
            }

            // Grant unlock
            if libc::grantpt(fd) == -1 {
                libc::close(fd);
                return Err(KuroError::Pty("Failed to grant PTY".to_string()));
            }

            // Unlock PTY
            if libc::unlockpt(fd) == -1 {
                libc::close(fd);
                return Err(KuroError::Pty("Failed to unlock PTY".to_string()));
            }

            fd
        };

        // Get PTY slave name
        let _slave_name = unsafe {
            let pts_name = libc::ptsname(master_fd);

            if pts_name.is_null() {
                libc::close(master_fd);
                return Err(KuroError::Pty("Failed to get PTY name".to_string()));
            }

            std::ffi::CStr::from_ptr(pts_name)
                .to_str()
                .map_err(|_| KuroError::Pty("Invalid PTY name".to_string()))?
                .to_string()
        };

        // Create bounded channel for backpressure
        let (sender, receiver) = crossbeam_channel::bounded(CHANNEL_CAPACITY);
        let shutdown = Arc::new(AtomicBool::new(false));

        // Duplicate the fd for the reader thread
        let duped_fd = unsafe { libc::dup(master_fd) };
        if duped_fd == -1 {
            unsafe { libc::close(master_fd) };
            return Err(KuroError::Pty("Failed to duplicate PTY fd".to_string()));
        }

        let reader_master = unsafe { std::fs::File::from_raw_fd(duped_fd) };
        let writer_master = unsafe { std::fs::File::from_raw_fd(master_fd) };

        // Fork using fork() - in production, use nix crate for safety
        // For now, we'll use a simpler approach with Command
        let child = Command::new(command)
            .stdin(std::process::Stdio::piped())
            .stdout(std::process::Stdio::piped())
            .stderr(std::process::Stdio::piped())
            .spawn()
            .map_err(|e| KuroError::Pty(format!("Failed to spawn shell: {}", e)))?;

        let child_pid = child.id() as libc::pid_t;

        // Clone shutdown for reader thread
        let shutdown_clone = shutdown.clone();

        // Spawn reader thread
        let reader_thread = thread::spawn(move || {
            PtyReader::read_loop(reader_master, sender, shutdown_clone);
        });

        Ok(Self {
            master: writer_master,
            child_pid,
            receiver,
            shutdown,
            _reader_thread: reader_thread,
        })
    }

    /// Write bytes to the PTY
    pub fn write(&mut self, bytes: &[u8]) -> Result<()> {
        use std::io::Write;

        self.master
            .write_all(bytes)
            .map_err(|e| KuroError::Pty(format!("Failed to write to PTY: {}", e)))?;

        Ok(())
    }

    /// Read bytes from the PTY (non-blocking, drains all available data)
    pub fn read(&mut self) -> Result<Vec<u8>> {
        let mut all_data = Vec::new();

        // Drain all available data from the channel
        while let Ok(data) = self.receiver.try_recv() {
            all_data.extend(data);
        }

        Ok(all_data)
    }

    /// Set PTY window size
    pub fn set_winsize(&mut self, rows: u16, cols: u16) -> Result<()> {
        let winsize = libc::winsize {
            ws_row: rows,
            ws_col: cols,
            ws_xpixel: 0,
            ws_ypixel: 0,
        };

        let result = unsafe { libc::ioctl(self.master.as_raw_fd(), libc::TIOCSWINSZ, &winsize) };

        if result == -1 {
            return Err(KuroError::Pty("Failed to set window size".to_string()));
        }

        Ok(())
    }

    /// Close the PTY
    pub fn close(self) -> Result<()> {
        // Signal reader thread to shutdown
        self.shutdown.store(true, Ordering::Relaxed);

        // Send SIGHUP to child
        unsafe {
            libc::kill(self.child_pid, libc::SIGHUP);
        }

        // Close master
        drop(self.master);

        Ok(())
    }
}

impl AsRawFd for Pty {
    fn as_raw_fd(&self) -> RawFd {
        self.master.as_raw_fd()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    #[cfg(unix)]
    fn test_pty_spawn() {
        let pty = Pty::spawn("bash");
        assert!(pty.is_ok());

        let mut pty = pty.unwrap();
        pty.write(b"echo test\n").unwrap();
    }
}
